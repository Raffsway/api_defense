# Copie este arquivo para .env e preencha com os dados do seu Defense IA.
# ============================================================================
#  AUTENTICACAO COM A PLATAFORMA INTELBRAS DEFENSE IA 3.2
# ============================================================================
DEFENSE_IP=192.168.1.1
DEFENSE_PORT=80
DEFENSE_USERNAME=system
DEFENSE_PASSWORD=troque_aqui

DEFENSE_SCHEME=http
DEFENSE_VERIFY_TLS=true
DEFENSE_CLIENT_MAC=2C-F0-5D-4D-5E-DB
DEFENSE_CLIENT_TYPE=WINPC_V2

DEFENSE_KEEPALIVE_INTERVAL=22
DEFENSE_UPDATE_TOKEN_EVERY=60
DEFENSE_HTTP_TIMEOUT=15
DEFENSE_DEFAULT_STREAM_TYPE=1
# A StartVideo pode devolver varios enderecos RTSP (interno|publico). Por padrao
# a API escolhe o que contiver o DEFENSE_IP. Para forcar outro host/IP no RTSP
# (ex.: IP interno alcancavel so na LAN), informe aqui. Vazio = automatico.
RTSP_HOST_OVERRIDE=

STREAM_FPS_LIMIT=0
# Qualidade JPEG. 95 = alta qualidade (recomendado p/ analise); 80 = mais leve.
STREAM_JPEG_QUALITY=95
# FPS reemitido por espectador. Full motion = 25; mural com varias cameras: 12-15.
STREAM_OUTPUT_FPS=15

# --- Decode por GPU (para dezenas de cameras simultaneas) ---
# Motor: "opencv" (CPU, padrao) ou "ffmpeg" (usa NVDEC/GPU se hwaccel=cuda).
STREAM_ENGINE=opencv
# Aceleracao do ffmpeg: "cuda" (RTX/NVDEC) ou "none". So vale com STREAM_ENGINE=ffmpeg.
STREAM_HWACCEL=cuda
# Caminho do ffmpeg (precisa de build com CUDA p/ NVDEC). Ex.: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=ffmpeg
# Reescala a largura do frame (0 = original). Ex.: 1280 reduz banda/CPU no mural.
STREAM_SCALE_WIDTH=0
# Segundos que a captura segue viva apos o ultimo espectador sair
STREAM_IDLE_GRACE=10
# Tempo maximo aguardando o 1o frame antes de encerrar (camera morta)
STREAM_FIRST_FRAME_TIMEOUT=20

API_HOST=0.0.0.0
API_PORT=8000

# Host/IP do servidor para o proxy HTTP/2 (Caddy) emitir o certificado interno.
# Use o IP que o navegador vai acessar (ex.: 192.168.0.50). Default: localhost.
CADDY_HOST=localhost
